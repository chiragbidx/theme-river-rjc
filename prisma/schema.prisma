generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  teams       Team[]     @relation("UserTeams")
  templates   Template[]
  keywords    Keyword[]
  pages       Page[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Team {
  id          String      @id @default(uuid())
  name        String
  users       User[]      @relation("UserTeams")
  templates   Template[]
  keywords    Keyword[]
  pages       Page[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Template {
  id          String     @id @default(uuid())
  name        String
  structure   Json
  user        User?      @relation(fields: [userId], references: [id])
  userId      String?
  team        Team?      @relation(fields: [teamId], references: [id])
  teamId      String?
  pages       Page[]
  keywords    Keyword[]  // For pre-linking default/campaign keywords
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Keyword {
  id            String   @id @default(uuid())
  value         String
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  team          Team?    @relation(fields: [teamId], references: [id])
  teamId        String?
  template      Template? @relation(fields: [templateId], references: [id])
  templateId    String?
  pages         Page[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Page {
  id            String    @id @default(uuid())
  url           String    @unique
  template      Template? @relation(fields: [templateId], references: [id])
  templateId    String?
  keyword       Keyword?  @relation(fields: [keywordId], references: [id])
  keywordId     String?
  user          User?     @relation(fields: [userId], references: [id])
  userId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  teamId        String?
  aiContent     String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}